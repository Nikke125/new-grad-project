page {
  background-color: #F7F8FA;
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 悬浮 Tab 栏 */
.tab-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background: #ffffff;
  display: flex;
  z-index: 100;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #333;
  font-weight: bold;
}

.underline {
  position: absolute;
  bottom: 12rpx;
  width: 40rpx;
  height: 6rpx;
  background: #3c9cff;
  border-radius: 3rpx;
}

/* 列表滚动区域 */
.list-view {
  flex: 1;
  padding-top: 120rpx;
  box-sizing: border-box;
}

/* 商品卡片 */
.product-card {
  background: #ffffff;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.product-info {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.details {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 160rpx;
}

.title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.symbol {
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-right: 16rpx;
}

.status-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  background: #f5f5f5;
  color: #999;
}

.tag-1 { background: #e6f7ff; color: #1890ff; } /* 在售 */
.tag-2 { background: #fff1f0; color: #ff4d4f; } /* 已下架 */

.publish-time {
  font-size: 22rpx;
  color: #b2b2b2;
}

/* 操作栏与幽灵按钮 */
.action-bar {
  border-top: 1rpx solid #f5f5f5;
  padding-top: 20rpx;
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.ghost-btn {
  margin: 0 !important;
  padding: 0 32rpx !important;
  height: 60rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  background: transparent !important;
  border: 2rpx solid #d9d9d9;
  border-radius: 30rpx;
  color: #666;
  font-weight: normal;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.ghost-btn.primary {
  border-color: #3c9cff;
  color: #3c9cff;
}

.ghost-btn.danger {
  border-color: #ff4d4f;
  color: #ff4d4f;
}

.btn-hover {
  transform: scale(0.95);
  opacity: 0.8;
}

.sold-tips {
  font-size: 24rpx;
  color: #999;
  font-style: italic;
}

/* 空状态 */
.empty-box {
  padding-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-box image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

.empty-box text {
  font-size: 28rpx;
  color: #999;
}
