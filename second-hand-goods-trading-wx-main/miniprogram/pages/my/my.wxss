page {
  background-color: #F7F8FA;
}

.container {
  padding: 20rpx 0 40rpx;
}

/* 用户卡片 */
.user-card {
  background: #ffffff;
  margin: 20rpx 30rpx 30rpx;
  padding: 40rpx 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.user-info-box {
  display: flex;
  align-items: center;
}

.avatar-box {
  width: 130rpx;
  height: 130rpx;
  border-radius: 65rpx;
  overflow: hidden;
  background: #f0f0f0;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
}

.avatar {
  width: 100%;
  height: 100%;
}

.info-text {
  margin-left: 30rpx;
  flex: 1;
}

.nickname {
  font-size: 38rpx;
  font-weight: 600;
  color: #333;
}

.login-text {
  color: #3c9cff;
}

.subtitle {
  font-size: 26rpx;
  color: #919191;
  margin-top: 12rpx;
}

.nickname-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

/* 信誉徽章样式 */
.credit-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  margin-left: 16rpx;
  white-space: nowrap;
  letter-spacing: 1rpx;
}

.badge-s {
  background: linear-gradient(135deg, #FDE08D 0%, #E6B139 100%);
  color: #7D5100;
  box-shadow: 0 4rpx 12rpx rgba(230, 177, 57, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.badge-a {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(67, 233, 123, 0.2);
}

.badge-c {
  background: #EAEAEA;
  color: #999;
  font-weight: normal;
}

.admin-tag {
  width: 44rpx;
  height: 44rpx;
  margin-left: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-tag image {
  width: 32rpx;
  height: 32rpx;
}

/* 交易中心卡片 */
.trading-card {
  background: #ffffff;
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  position: relative;
}

.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: #3c9cff;
  border-radius: 3rpx;
}

.grid-box {
  display: flex;
  flex-wrap: wrap;
}

.grid-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.grid-item image {
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 16rpx;
}

.grid-item text {
  font-size: 26rpx;
  color: #555;
}

/* 底部列表样式 */
.list-section {
  margin: 0 30rpx;
}

.list-item {
  background: #ffffff;
  margin-bottom: 20rpx;
  padding: 32rpx 30rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}

.item-left {
  display: flex;
  align-items: center;
}

.item-left image {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
}

.item-left text {
  font-size: 28rpx;
  color: #333;
  letter-spacing: 1rpx;
}

.arrow {
  width: 14rpx;
  height: 25rpx;
  opacity: 0.3;
}
