page {
  background: #F7F8FA;
  width: 100%;
  height: 100%;
}

/* 顶部搜索栏区域，毛玻璃质感 */
.top_header_blur_background {
  position: sticky;
  top: 0;
  width: 100%;
  z-index: 99;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(220, 222, 225, 0.3);
}

.top_box {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

.top_list {
  width: 50rpx;
  height: 50rpx;
  opacity: 0.7;
  transition: all 0.2s ease-in-out;
}

.top_list:active {
  opacity: 0.5;
  transform: scale(0.95);
}

/* 搜索框 - 胶囊形 */
.search_box {
  width: 610rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(240, 242, 245, 0.8);
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.search_box:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
  background: rgba(235, 238, 242, 0.9);
}

.search_ico {
  padding-left: 30rpx;
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
}

.search_text {
  padding-left: 10rpx;
  font-size: 28rpx;
  letter-spacing: 1rpx;
  color: #8C949F;
  flex: 1;
}

/* 轮播图 */
.banner {
  width: 100%;
  display: flex;
  box-sizing: border-box;
  height: 280rpx;
}

.banner_image {
  width: 100%;
  padding: 16rpx 20rpx 12rpx 20rpx;
  box-sizing: border-box;
  height: inherit;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 25rpx rgba(0, 0, 0, 0.08);
}

::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}

.space {
  width: 100%;
  height: 20rpx;
  background: transparent;
}

/* 分类导航 - 游戏化菜单风格 */
.kind_contain_fixed_wrapper {
  width: 100%;
  z-index: 50;
  position: sticky;
  top: 112rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1rpx solid rgba(220, 222, 225, 0.25);
  transition: all 0.3s ease-in-out;
}

.kind_contain {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: transparent;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav {
  flex: 1;
  height: 100%;
  white-space: nowrap;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
}

.nav::-webkit-scrollbar {
  display: none;
}

/* 药丸形状 Tab */
.nav-item {
  display: inline-block;
  justify-content: center;
  align-items: center;
  min-width: 160rpx;
  height: 70rpx;
  margin: 0 10rpx;
  font-size: 28rpx;
  color: #9BA3AD;
  letter-spacing: 1rpx;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  border-radius: 35rpx;
  padding: 0 25rpx;
  background: transparent;
  line-height: 70rpx;
  text-align: center;
  flex-shrink: 0;
}

.nav-text {
  font-size: inherit;
  color: inherit;
  font-weight: normal;
  transition: all 0.3s ease-in-out;
}

/* 选中状态 - 药丸背景 */
.nav-item.tab-on {
  background: #6AFFD9;
  color: #2D3748;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(106, 255, 217, 0.35);
  transform: translateY(-2rpx);
}

.nav-item.tab-on .nav-text {
  color: #2D3748;
  font-weight: 600;
}

.kind_img {
  width: 80rpx;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0.7;
  transition: all 0.2s ease-in-out;
  flex-shrink: 0;
}

.kind_img:active {
  opacity: 0.5;
  transform: scale(0.9);
}

.kind_img image {
  width: 32rpx;
  height: 32rpx;
}

.kindlist_box {
  position: absolute;
  width: 100%;
  top: 100rpx;
  left: 0rpx;
  border-bottom: 1rpx solid rgba(220, 222, 225, 0.25);
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 60;
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.kindlist_card {
  padding: 20rpx 20rpx 0 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.list_grid {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
}

.list_one {
  width: 25%;
  padding: 0 10rpx 20rpx 10rpx;
  box-sizing: border-box;
}

.list_one view {
  width: 100%;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #E5E7EB;
  border-radius: 10rpx;
  font-size: 28rpx;
  letter-spacing: 1rpx;
  color: #6B7280;
  background: #F3F4F6;
  transition: all 0.2s ease-in-out;
}

.list_one view:active {
  transform: scale(0.95);
}

.list_one view.list-on {
  background: #6AFFD9;
  color: #2D3748;
  border: none;
  box-shadow: 0 3rpx 12rpx rgba(106, 255, 217, 0.3);
  font-weight: 600;
}

/* 瀑布流样式 */
.waterfall_container {
  background: transparent;
  padding: 20rpx;
}

.card_grid {
  column-count: 2;
  column-gap: 24rpx;
  width: 100%;
}

.card_one {
  break-inside: avoid;
  margin-bottom: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.card_one:active {
  transform: translateY(-6rpx);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.1);
}

.card_poster {
  width: 100%;
  height: auto;
  display: block;
  background: #EAECEF;
}

.card_info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.card_title {
  font-size: 30rpx;
  color: #2D3748;
  line-height: 44rpx;
  font-weight: 600;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.card_price_box {
  display: flex;
  align-items: baseline;
  color: #FF6B6B;
  margin-bottom: 20rpx;
}

.price_symbol {
  font-size: 26rpx;
  font-weight: bold;
}

.price_value {
  font-size: 38rpx;
  font-weight: bold;
  margin-left: 4rpx;
}

.card_user {
  display: flex;
  align-items: center;
  border-top: 1rpx solid #F0F2F5;
  padding-top: 16rpx;
}

.card_user_avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #DCE0E6;
  margin-right: 12rpx;
}

.card_user_name {
  font-size: 24rpx;
  color: #8C949F;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

/* 列表显示样式 */
.list_box {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 20rpx;
  box-sizing: border-box;
  margin: 0 20rpx 20rpx 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.list_box:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.08);
}

.list_poster {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #EAECEF;
  flex-shrink: 0;
}

.list_content {
  height: 200rpx;
  width: calc(100% - 200rpx);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.list_word {
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

.list_title {
  width: 100%;
  font-size: 32rpx;
  letter-spacing: 2rpx;
  line-height: 48rpx;
  color: #2D3748;
  font-weight: 600;
}

.list_author {
  padding-top: 8rpx;
  width: 100%;
  font-size: 26rpx;
  letter-spacing: 1rpx;
  line-height: 36rpx;
  color: #8C949F;
}

.list_between {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  border-bottom: none;
  padding-bottom: 0;
  margin-top: 10rpx;
}

.list_price {
  font-size: 36rpx;
  color: #FF6B6B;
  font-weight: bold;
}

.list_time {
  font-size: 26rpx;
  letter-spacing: 1rpx;
  color: #A0AEC0;
}

/* 空状态 - 阿初与小宝专属 IP */
.nocontent {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  padding: 120rpx 40rpx;
  box-sizing: border-box;
  background: transparent;
  min-height: 600rpx;
}

.nocontent_image {
  width: 480rpx;
  height: 480rpx;
  margin-bottom: 50rpx;
  opacity: 0.95;
  animation: fadeInScale 0.5s ease-out;
}

@keyframes fadeInScale {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 0.95;
    transform: scale(1);
  }
}

.nocontent_title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3748;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.nocontent_subtitle {
  font-size: 28rpx;
  color: #8C949F;
  letter-spacing: 1rpx;
  line-height: 42rpx;
  text-align: center;
}

/* 返回顶部按钮 */
.totop {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  z-index: 90;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.totop image {
  width: 90rpx;
  height: 90rpx;
  opacity: 0.8;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
  border-radius: 50%;
  transition: all 0.2s ease-in-out;
}

.totop image:active {
  transform: scale(0.92);
  opacity: 0.9;
}

/* 发布悬浮按钮 (FAB) */
.publish_fab {
  position: fixed;
  right: 40rpx;
  bottom: 20rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(106, 255, 217, 0.92);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 16rpx 45rpx rgba(106, 255, 217, 0.45);
  z-index: 100;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.publish_fab:active {
  transform: scale(0.88);
  box-shadow: 0 8rpx 25rpx rgba(106, 255, 217, 0.5);
}

.publish_fab_hover {
  transform: scale(0.88);
  box-shadow: 0 8rpx 25rpx rgba(106, 255, 217, 0.5);
}

.plus_icon {
  position: relative;
  width: 50rpx;
  height: 50rpx;
}

.plus_icon::before,
.plus_icon::after {
  content: '';
  position: absolute;
  background: #2D3748;
  border-radius: 4rpx;
}

.plus_icon::before {
  width: 100%;
  height: 8rpx;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
}

.plus_icon::after {
  width: 8rpx;
  height: 100%;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
}

.fixed {
  position: fixed;
  left: 0rpx;
  top: 0rpx;
}

.nofixed {
  height: 91rpx;
  width: 100%;
  background: #fff;
}
